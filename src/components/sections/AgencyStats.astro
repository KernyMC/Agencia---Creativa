---
---
<section>
  <!-- Pink banner -->
  <div class="agency-stats__banner">
    <div class="container">
      <h2 class="section-header">Sobre nuestra agencia</h2>
    </div>
  </div>

  <!-- Body: image + stats -->
  <div class="agency-stats__body">
    <div class="agency-stats__media">
      <!-- Reemplaza con tu imagen real: mujer de rosa con teléfono -->
      <img
        src="https://cdn.sanity.io/images/q0vsroiq/production/4e2a7f71fbd46712fd93c655d6105f877dbb2c58-1599x1066.webp"
        alt="Agencia Creativa"
        class="parallax-img"
      />
    </div>
    <div class="agency-stats__data">
      <div class="stat-block fade-up">
        <span class="stat-block__badge">Cobertura</span>
        <div
          class="stat-block__number stat-number"
          data-prefix="+"
          data-value="4"
          data-suffix=" ciudades"
        >+4 ciudades</div>
        <p class="stat-block__desc">
          El Ángel, Ibarra, Quito y el Valle de los Chillos.
        </p>
      </div>

      <div class="stat-block fade-up">
        <span class="stat-block__badge">Experiencia</span>
        <div
          class="stat-block__number stat-number"
          data-prefix="+"
          data-value="10"
          data-suffix=" sectores"
        >+10 sectores</div>
        <p class="stat-block__desc">
          Turismo, Educación, Financiero, Alimentación, Bienes Raíces y más
        </p>
      </div>
    </div>
  </div>
</section>
