---
const team = [
  {
    name: "Malena Romero",
    role: "Coordinadora ATL y BTL",
    bio: "Junto a Kathe coordinan tus publicaciones y contactan a tus proveedores.",
    photo: "https://cdn.sanity.io/images/q0vsroiq/production/b0ce356df4537d575b80b53bd508ce46e8de3bb8-799x799.heif",
  },
  {
    name: "Pepita Perez",
    role: "International Business Operations & Digital Strategy Manager",
    bio: "Administradora de empresas con visión global. Encargada de la expansión de Creativa en Canadá, impulsando el crecimiento de PYMES mediante marketing digital, CRM y branding estratégico.",
    photo: "https://cdn.sanity.io/images/q0vsroiq/production/fe5bc2917e07b9f12422dde81cffaa3b38c110b7-688x1445.jpg",
  },
  {
    name: "Luis Lopez",
    role: "Editor de vídeos",
    bio: "Transforma momentos simples en emociones visuales que inspiran.",
    photo: "https://cdn.sanity.io/images/q0vsroiq/production/91522fdf13952653c5e44b0ea33f4dbd3b88d1d5-533x800.heif",
  },
  {
    name: "Mateo Minda",
    role: "Fotógrafo profesional",
    bio: "Captura imágenes que reflejan la esencia de cada marca.",
    photo: "https://cdn.sanity.io/images/q0vsroiq/production/5f3b422785cecfd270f187a028be89a75b6649b6-640x640.heif",
  },
];
---

<section class="team" id="equipo">
  <div class="team__surface">
    <div class="container team__header">
      <h2 class="team__title section-header">
        Nuestro <span>equipo</span>
      </h2>
    </div>

    <div class="cards">
      {team.map((member) => (
        <div class="card team-card">
          <div class="card__photo">
            <img src={member.photo} alt={`Retrato de ${member.name}`} loading="lazy" decoding="async" />
            <div class="card__gradient"></div>
            <span class="card__name">{member.name}</span>
          </div>
          <div class="card__bio">
            <strong class="card__role">{member.role}</strong>
            <p class="card__text">{member.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .team {
    padding: var(--section-pad) 0;
    background: #fff;
    overflow: hidden;
  }
  .team__surface {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(28px, 5vw, 48px);
  }
  .team__header { text-align: center; }
  .team__title  { margin-bottom: 0; }

  /* Contenedor: overflow+radius solo aquí */
  .cards {
    display: flex;
    flex-wrap: nowrap;
    width: min(1170px, 80vw);
    height: 400px;
    margin: 0 auto;
    overflow: hidden;
    border-radius: 1rem;
    box-shadow: 0 26px 70px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,255,255,0.5);
  }

  /* ── Card: SOLO flex para el ancho exterior, position:relative para hijos ──
     Sin display:flex interno — evita el bug de flex-basis:% con flex-basis:0
  ──────────────────────────────────────────────────────────────────────────── */
  .card {
    position: relative;      /* containing block para los hijos absolute */
    flex: 1 1 0;
    min-width: 0;
    height: 100%;
    overflow: hidden;
    cursor: pointer;
    transition: flex 0.55s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card:hover { flex: 4 1 0; }

  .cards:has(.card:hover) .card:not(:hover) { flex: 0.65 1 0; }

  /* ── Foto: absolute, llena toda la card (inset:0) ──────────────────────────
     En hover: right:60% la estrecha al 40% izquierdo.
     Los % se calculan sobre el ancho COMPUTED de .card (el containing block),
     no sobre flex-basis — esto es fiable en todos los browsers.
  ──────────────────────────────────────────────────────────────────────────── */
  .card__photo {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    overflow: hidden;
    transition: right 0.55s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card:hover .card__photo { right: 60%; }

  .card__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(100%);
    transition: filter 0.55s ease;
  }
  .card:hover .card__photo img { filter: grayscale(0%); }

  .card__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.22) 38%, transparent 62%);
    pointer-events: none;
  }

  .card__name {
    position: absolute;
    bottom: 1rem; left: 1rem; right: 1rem;
    color: #fff;
    font-size: 0.92rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    text-shadow: 0 1px 8px rgba(0,0,0,0.6);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Bio: absolute en el 60% derecho, oculto por defecto ───────────────────
     width:0 → width:60% anima sobre el ancho computed del card (fiable).
  ──────────────────────────────────────────────────────────────────────────── */
  .card__bio {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 0;
    overflow: hidden;
    background: #111;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.8rem;
    padding: 0;
    opacity: 0;
    white-space: normal;
    transition:
      width   0.55s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.3s  ease 0.22s,
      padding 0.45s ease;
  }

  .card:hover .card__bio {
    width: 60%;
    opacity: 1;
    padding: 2rem 1.5rem;
  }

  .card__role {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pink);
    line-height: 1.5;
  }
  .card__text {
    font-size: 0.875rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.78);
    margin: 0;
  }

  /* Mobile */
  @media (max-width: 600px) {
    .cards { flex-direction: column; height: auto; width: 90vw; }
    .card  { flex: none; width: 100%; height: 220px; }
    .card:hover { flex: none; }
    .cards:has(.card:hover) .card:not(:hover) { flex: none; }
    .card:hover .card__photo { right: 0; }
    .card__bio { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .card, .card__photo, .card__photo img, .card__bio { transition: none; }
  }
</style>
