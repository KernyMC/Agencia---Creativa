---
const links = [
  { label: "Inicio", href: "#inicio" },
  { label: "Nosotros", href: "#nosotros" },
  { label: "Servicios", href: "#servicios" },
  { label: "Equipo", href: "#equipo" },
  { label: "Portafolio", href: "#portafolio" },
  { label: "Contacto", href: "#contacto" },
];
---

<!-- Scroll progress bar -->
<div class="nav-progress" id="navProgress" aria-hidden="true"></div>

<header class="site-header hero__logo" id="siteHeader">
  <div class="container">
    <div class="header__inner">
      <!-- Brand -->
      <a href="#inicio" class="header__brand" aria-label="Creativa — inicio">
        <img
          src="https://cdn.sanity.io/images/q0vsroiq/production/a61976488d2b2a58ecfef9fd94b9e1406c90194d-799x792.webp"
          alt="Logo Creativa"
          class="header__brand-logo"
          width="44"
          height="44"
          loading="eager"
        />
        <span class="header__brand-text">
          <span class="header__brand-name">CREATIVA</span>
          <span class="header__brand-sub"
            >Agencia de Marketing y Publicidad</span
          >
        </span>
      </a>

      <!-- Nav desktop -->
      <nav class="nav" aria-label="Navegación principal">
        <ul class="nav__list">
          {
            links.map((link) => (
              <li class="nav__item">
                <a href={link.href} class="nav__link" data-navlink>
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- CTA + hamburger -->
      <div class="header__actions">
        <button
          type="button"
          class="btn btn--pink header__cta-btn"
          data-open-calendly
        >
          Asesoría gratis
        </button>
        <button
          class="hamburger"
          id="hamburgerBtn"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="mobileMenu"
        >
          <span class="hamburger__line"></span>
          <span class="hamburger__line"></span>
          <span class="hamburger__line"></span>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile menu -->
<div class="mobile-menu" id="mobileMenu" aria-hidden="true">
  <nav aria-label="Menú móvil">
    <ul class="mobile-menu__list">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class="mobile-menu__link" data-mobilelink>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
  <button
    type="button"
    class="btn btn--pink mobile-menu__cta"
    data-open-calendly
  >
    Asesoría gratis
  </button>
</div>
<!-- Backdrop -->
<div class="mobile-backdrop" id="mobileBackdrop" aria-hidden="true"></div>

<!-- Calendly modal -->
<div class="calendly-modal" id="calendlyModal" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Agenda tu asesoría">
  <div class="calendly-modal__backdrop" id="calendlyBackdrop"></div>
  <div class="calendly-modal__panel" role="document">
    <button type="button" class="calendly-modal__close" id="calendlyClose" aria-label="Cerrar calendario">Cerrar</button>
    <div
      class="calendly-inline-widget"
      data-url="https://calendly.com/creativamarketinguio/30min?primary_color=e8007d"
      style="min-width:320px;height:700px;"
    ></div>
  </div>
</div>

<script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>

<style>
  /* ---- Scroll progress ---- */
  .nav-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 3px;
    width: 0%;
    background: linear-gradient(90deg, var(--pink), var(--pink-light));
    z-index: 200;
    transition: width 0.1s linear;
    border-radius: 0 2px 2px 0;
  }

  /* ---- Header ---- */
  .site-header {
    position: fixed;
    top: 3px;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(245, 240, 234, 0.92);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(232, 0, 125, 0.1);
    padding: 14px 0;
    transition:
      box-shadow 0.3s,
      background 0.3s;
  }
  .site-header.is-scrolled {
    box-shadow: 0 4px 24px rgba(26, 10, 77, 0.1);
    background: rgba(245, 240, 234, 0.97);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  /* Brand */
  .header__brand {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    line-height: 1;
    flex-shrink: 0;
    text-decoration: none;
  }
  .header__brand-logo {
    width: 44px;
    height: 44px;
    object-fit: contain;
    border-radius: 8px;
    flex-shrink: 0;
  }
  .header__brand-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .header__brand-name {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--pink);
    letter-spacing: -0.02em;
  }
  .header__brand-sub {
    font-size: 0.62rem;
    font-weight: 600;
    color: var(--dark);
    letter-spacing: 0.04em;
  }

  /* Desktop nav */
  .nav {
    margin-left: auto;
  }
  .nav__list {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
  }
  .nav__link {
    position: relative;
    padding: 8px 14px;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--dark);
    letter-spacing: 0.03em;
    border-radius: 50px;
    transition:
      color 0.2s,
      background 0.2s;
    text-decoration: none;
  }
  .nav__link::after {
    content: "";
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    width: 16px;
    height: 2px;
    border-radius: 2px;
    background: var(--pink);
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .nav__link:hover,
  .nav__link.is-active {
    color: var(--pink);
    background: rgba(232, 0, 125, 0.07);
  }
  .nav__link.is-active::after,
  .nav__link:hover::after {
    transform: translateX(-50%) scaleX(1);
  }

  /* Actions */
  .header__actions {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-left: 12px;
  }
  .header__cta-btn {
    font-size: 0.78rem;
    padding: 10px 22px;
    white-space: nowrap;
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 8px;
    background: transparent;
    border: none;
    cursor: pointer;
    border-radius: 8px;
    transition: background 0.2s;
  }
  .hamburger:hover {
    background: rgba(232, 0, 125, 0.08);
  }
  .hamburger__line {
    display: block;
    height: 2px;
    background: var(--dark);
    border-radius: 2px;
    transition:
      transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.2s,
      width 0.3s;
  }
  .hamburger__line:nth-child(1) {
    width: 24px;
  }
  .hamburger__line:nth-child(2) {
    width: 18px;
  }
  .hamburger__line:nth-child(3) {
    width: 24px;
  }
  .hamburger.is-open .hamburger__line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
    width: 24px;
  }
  .hamburger.is-open .hamburger__line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .hamburger.is-open .hamburger__line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
    width: 24px;
  }

  /* ---- Mobile menu ---- */
  .mobile-menu {
    position: fixed;
    top: 0;
    right: 0;
    width: min(320px, 85vw);
    height: 100dvh;
    background: var(--cream);
    z-index: 150;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
    display: flex;
    flex-direction: column;
    padding: 100px 32px 48px;
    gap: 48px;
    box-shadow: -8px 0 40px rgba(26, 10, 77, 0.15);
  }
  .mobile-menu.is-open {
    transform: translateX(0);
  }
  .mobile-menu__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .mobile-menu__link {
    display: block;
    padding: 14px 16px;
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--dark);
    border-radius: 12px;
    transition:
      color 0.2s,
      background 0.2s,
      transform 0.2s;
    text-decoration: none;
  }
  .mobile-menu__link:hover,
  .mobile-menu__link.is-active {
    color: var(--pink);
    background: rgba(232, 0, 125, 0.07);
    transform: translateX(4px);
  }
  .mobile-menu__cta {
    width: 100%;
    justify-content: center;
    font-size: 0.9rem;
  }

  /* Backdrop */
  .mobile-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(26, 10, 77, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 140;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
  }
  .mobile-backdrop.is-open {
    opacity: 1;
    pointer-events: all;
  }

  /* Calendly modal */
  .calendly-modal {
    position: fixed;
    inset: 0;
    z-index: 260;
    display: none;
  }
  .calendly-modal.is-open {
    display: block;
  }
  .calendly-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(13, 13, 13, 0.5);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
  }
  .calendly-modal__panel {
    position: relative;
    z-index: 1;
    width: min(960px, calc(100vw - 24px));
    margin: clamp(8px, 2vw, 24px) auto;
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
  }
  .calendly-modal__close {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 2;
    border: 0;
    border-radius: 999px;
    background: rgba(26, 10, 77, 0.92);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    padding: 8px 12px;
    cursor: pointer;
  }
  .calendly-modal .calendly-inline-widget {
    width: 100%;
  }

  /* ---- Responsive ---- */
  @media (max-width: 860px) {
    .nav {
      display: none;
    }
    .header__cta-btn {
      display: none;
    }
    .hamburger {
      display: flex;
    }
  }
</style>

<script>
  const header = document.getElementById("siteHeader")!;
  const progress = document.getElementById("navProgress")!;
  const hamburger = document.getElementById("hamburgerBtn")!;
  const mobileMenu = document.getElementById("mobileMenu")!;
  const backdrop = document.getElementById("mobileBackdrop")!;
  const navLinks =
    document.querySelectorAll<HTMLAnchorElement>("[data-navlink]");
  const mobileLinks =
    document.querySelectorAll<HTMLAnchorElement>("[data-mobilelink]");
  const calendlyButtons =
    document.querySelectorAll<HTMLButtonElement>("[data-open-calendly]");
  const calendlyModal = document.getElementById("calendlyModal")!;
  const calendlyBackdrop = document.getElementById("calendlyBackdrop")!;
  const calendlyClose = document.getElementById("calendlyClose")!;

  // ── Scroll progress ──────────────────────────
  function updateProgress() {
    const h = document.documentElement;
    const pct = (h.scrollTop / (h.scrollHeight - h.clientHeight)) * 100;
    progress.style.width = pct + "%";
  }

  // ── Scrolled state ────────────────────────────
  function updateScrolled() {
    header.classList.toggle("is-scrolled", window.scrollY > 40);
  }

  // ── Active section detection ──────────────────
  const sections = [
    "inicio",
    "nosotros",
    "servicios",
    "equipo",
    "portafolio",
    "contacto",
  ]
    .map((id) => document.getElementById(id))
    .filter(Boolean) as HTMLElement[];

  function updateActive() {
    let current = sections[0]?.id ?? "";
    for (const sec of sections) {
      if (window.scrollY >= sec.offsetTop - 100) current = sec.id;
    }
    const setActive = (links: NodeListOf<HTMLAnchorElement>) => {
      links.forEach((a) => {
        a.classList.toggle(
          "is-active",
          a.getAttribute("href") === "#" + current,
        );
      });
    };
    setActive(navLinks);
    setActive(mobileLinks);
  }

  window.addEventListener(
    "scroll",
    () => {
      updateProgress();
      updateScrolled();
      updateActive();
    },
    { passive: true },
  );

  updateActive();

  // ── Hamburger ─────────────────────────────────
  function openMenu() {
    hamburger.classList.add("is-open");
    mobileMenu.classList.add("is-open");
    backdrop.classList.add("is-open");
    hamburger.setAttribute("aria-expanded", "true");
    mobileMenu.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    hamburger.classList.remove("is-open");
    mobileMenu.classList.remove("is-open");
    backdrop.classList.remove("is-open");
    hamburger.setAttribute("aria-expanded", "false");
    mobileMenu.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  function openCalendly() {
    closeMenu();
    calendlyModal.classList.add("is-open");
    calendlyModal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeCalendly() {
    calendlyModal.classList.remove("is-open");
    calendlyModal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  hamburger.addEventListener("click", () =>
    hamburger.classList.contains("is-open") ? closeMenu() : openMenu(),
  );
  backdrop.addEventListener("click", closeMenu);
  calendlyBackdrop.addEventListener("click", closeCalendly);
  calendlyClose.addEventListener("click", closeCalendly);
  calendlyButtons.forEach((btn) => {
    btn.addEventListener("click", openCalendly);
  });
  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && calendlyModal.classList.contains("is-open")) {
      closeCalendly();
    }
  });

  // Close + smooth scroll on mobile links
  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      closeMenu();
    });
  });

  // ── Smooth scroll for all anchor links ────────
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", (e) => {
      const href = (anchor as HTMLAnchorElement).getAttribute("href");
      if (!href || href === "#") return;
      const target = document.querySelector(href);
      if (!target) return;
      e.preventDefault();
      const offset = header.offsetHeight + 12;
      const top = (target as HTMLElement).offsetTop - offset;
      window.scrollTo({ top, behavior: "smooth" });
    });
  });
</script>
