---
interface Props {
  title: string;
  description?: string;
  image?: string;
  href?: string;
}

const { title, description, image, href } = Astro.props;
---

<article class="card">
  {image && <img src={image} alt={title} />}
  <div class="card__body">
    <h3>{title}</h3>
    {description && <p>{description}</p>}
    {href && <a href={href}>Ver más</a>}
  </div>
</article>
