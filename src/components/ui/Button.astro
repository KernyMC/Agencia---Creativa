---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "outline";
  type?: "button" | "submit" | "reset";
}

const { href, variant = "primary", type = "button" } = Astro.props;
---

{href ? (
  <a href={href} class={`btn btn--${variant}`}>
    <slot />
  </a>
) : (
  <button type={type} class={`btn btn--${variant}`}>
    <slot />
  </button>
)}
